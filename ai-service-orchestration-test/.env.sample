# ai-service-orchestration-test — environment template
#
# Copy this file to `.env` (git-ignored) in this directory and fill in the values.
# run-integration-test.sh sources `.env` and exports every key: FunctionTestBase reads them
# via System.getenv and passes them into each locally started Function host (`func host start`).
#
# Auth for the test runner's own storage clients (blob/table/queue setup + teardown) and for
# the functions' SDK clients is DefaultAzureCredential — run `az login` first. The one
# exception is AzureWebJobsStorage below, which the Functions host itself requires.

# --- Storage account hosting the test containers/tables/queues ---
# Account NAME only (endpoints are derived); also used as the identity-based binding account.
AI_RAG_SERVICE_STORAGE_ACCOUNT_CONNECTION_STRING__accountName=<storage-account-name>

# Functions host bookkeeping storage. The host requires a full key-based connection string:
# paste the complete "Connection string" value from Portal -> storage account -> Access keys.
# KEEP THE SINGLE QUOTES — the value contains semicolons, which bash otherwise treats as
# command separators when the file is sourced. Test-only; production code never uses
# connection strings (managed identity only).
AzureWebJobsStorage='<paste-connection-string-from-portal-access-keys>'

# --- Document Intelligence (ingestion content extraction) ---
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-document-intelligence>.cognitiveservices.azure.com/

# --- Azure AI Search ---
AZURE_SEARCH_SERVICE_ENDPOINT=https://<your-search-service>.search.windows.net
# AZURE_SEARCH_SERVICE_INDEX_NAME is no longer used: the harness creates per-run test indexes (v1+v2 schemas) and points the hosts at the v2 one

# --- Azure OpenAI (embeddings) ---
AZURE_EMBEDDING_SERVICE_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_EMBEDDING_SERVICE_DEPLOYMENT_NAME=text-embedding-3-large

# --- Azure OpenAI (answer generation chat) ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-response-generation

# --- Azure OpenAI (scoring judge) ---
AZURE_JUDGE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_JUDGE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-judge

# --- Azure Monitor (scoring metrics) ---
# Paste the complete "Connection String" from Portal -> Application Insights -> Overview.
# Keep the single quotes (semicolons in the value).
RECORD_SCORE_AZURE_INSIGHTS_CONNECTION_STRING='<paste-connection-string-from-app-insights-overview>'
