# ai-document-system-prompt-harness-eval — environment template
#
# Copy this file to `.env` (git-ignored) in this directory and fill in the endpoints.
# run-harness.sh sources `.env` and exports every key, because the production services the
# harness drives read their config via System.getenv (the JVM cannot set its own env vars).
#
# Auth is managed identity / DefaultAzureCredential — run `az login` before the harness.
# No API keys are needed (the SDK client factories use a bearer token from the credential chain).

# --- Azure OpenAI (chat) ---
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.cognitiveservices.azure.com/
# 'azure' selects AzureChatService, which omits temperature/top_p for reasoning models and
# honours LLM_REASONING_EFFORT. (Note: OpenAiChatService does NOT apply reasoning effort.)
LLM_CHAT_SERVICE_PROVIDER=azure
# Shared by hidden reasoning + answer + JSON on reasoning models; keep generous for gpt-5.1.
LLM_MODEL_RESPONSE_MAX_TOKENS=7000
# Reasoning models only (gpt-5.1 / o-series); ignored by gpt-4o. 'none' eliminates the
# reasoning-token truncation observed in the round-2 evaluation. Other values: minimal|low|medium|high.
LLM_REASONING_EFFORT=none

# --- Azure OpenAI (embeddings) ---
AZURE_EMBEDDING_SERVICE_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_EMBEDDING_SERVICE_DEPLOYMENT_NAME=text-embedding-3-large

# --- Azure AI Search + retrieval refinement pipeline ---
# Sizing chain must hold: kNN >= pool > MMR final count (see CLAUDE.md).
AZURE_SEARCH_SERVICE_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_SERVICE_INDEX_NAME=ai-rag-service-index
SEARCH_NEAREST_NEIGHBOURS_COUNT=80
SEARCH_TOP_RESULTS_COUNT=60
# Stage 1: information-safe containment dedup.
SEARCH_RESULTS_ENABLE_CONTAINMENT_DEDUP=true
SEARCH_CONTAINMENT_SHINGLE_SIZE=3
SEARCH_CONTAINMENT_THRESHOLD=0.95
# Stage 2: legacy cosine semantic dedup — superseded by containment; keep disabled.
SEARCH_RESULTS_ENABLE_DEDUPLICATION=false
SEARCH_RESULTS_SEMANTIC_DEDUPLICATION_THRESHOLD=0.95
# Stage 3: MMR diversification; final count = chunks sent to the LLM.
SEARCH_RESULTS_ENABLE_MMR=true
SEARCH_MMR_LAMBDA=0.5
SEARCH_MMR_FINAL_COUNT=15

# --- Citation guard (answer-retrieval code the harness drives) ---
# 'off' for measurement runs: degraded answers flow into the metrics instead of throwing
# CitationDegradedException (which the harness records as an ERROR cell). deliver|reject|off.
CITATION_GUARD_MODE=off

# --- HTTP / retry ---
# run-harness.sh applies NO floors or defaults — set gpt-5.1-safe timeouts here
# (reasoning calls can run minutes with no bytes flowing; read>=300, response>=600).
AZURE_CLIENT_MAX_RETRIES=3
AZURE_CLIENT_BASE_DELAY_IN_SECONDS=1
AZURE_CLIENT_MAX_DELAY_IN_SECONDS=60
HTTP_CLIENT_RESPONSE_TIMEOUT_IN_SECONDS=600
HTTP_CLIENT_CONNECT_TIMEOUT_IN_SECONDS=10
HTTP_CLIENT_READ_TIMEOUT_IN_SECONDS=300

# --- Harness knobs ---
# Comma-separated system-prompt file names (without .txt) under src/main/resources/prompts,
# in display order. The quality comparison pairs each prompt against its predecessor.
HARNESS_SYSTEM_PROMPTS=v4-strict-citation-grouping-compact
# Comma-separated chat deployment names; all share AZURE_OPENAI_ENDPOINT.
HARNESS_LLM_DEPLOYMENTS=gpt-5.1,gpt-4o-response-generation
# Comma-separated document ids the queries target; every query runs against every id
# (with >1 id, report rows are suffixed with the id's first 8 chars).
HARNESS_DOCUMENT_IDS=4fa52386-d5f2-4b61-bc8c-c28cb02093ee,22e543b6-9f10-49db-9119-94a41fc02002
# Iterations per (prompt × LLM × query) cell.
HARNESS_REPETITIONS=2
# Delay (seconds) before each LLM call, to avoid tripping the deployment's TPM quota.
HARNESS_CALL_DELAY_SECONDS=5
# Uncomment to run only the first N queries (fast smoke test).
# HARNESS_MAX_QUERIES=1
# Quality-comparison stage (system-prompt chain and/or query-version pairs): judge toggle + deployment.
HARNESS_JUDGE=true
HARNESS_JUDGE_DEPLOYMENT=gpt-5.1
